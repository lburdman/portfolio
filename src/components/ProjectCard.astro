---
import type { CollectionEntry } from 'astro:content';
import type { UIStrings, Locale } from '@/i18n/types';

interface Props {
  project: CollectionEntry<'projects'>;
  t: UIStrings;
  locale: Locale;
  base: string;
}

const { project, t, locale, base } = Astro.props;
const { title, summary, tags, github, demo, projectSlug } = project.data;
const projectURL = locale === 'en' ? `${base}/projects/${projectSlug}` : `${base}/es/projects/${projectSlug}`;
---

<article class="card group flex flex-col gap-5 hover:cursor-pointer" data-project={projectSlug}>
  <!-- Header -->
  <div class="flex flex-col gap-2">
    <h3 class="text-base font-semibold text-text-primary group-hover:text-white transition-colors leading-snug">
      <a href={projectURL} class="outline-none focus-visible:ring-2 focus-visible:ring-accent rounded">
        {title}
      </a>
    </h3>
    <p class="text-sm text-text-secondary leading-relaxed line-clamp-3">{summary}</p>
  </div>

  <!-- Tags -->
  <div class="flex flex-wrap gap-1.5" aria-label="Technologies">
    {tags.map((tag) => <span class="tag">{tag}</span>)}
  </div>

  <!-- Links -->
  <div class="mt-auto flex items-center gap-3 pt-2 border-t border-surface-border">
    <a
      href={projectURL}
      class="text-xs font-medium text-accent-hover hover:text-white transition-colors"
      id={`project-link-${projectSlug}`}
    >
      {t.projects.viewProject} →
    </a>
    {
      github && (
        <a
          href={github}
          target="_blank"
          rel="noopener noreferrer"
          class="ml-auto text-xs text-text-muted hover:text-text-secondary transition-colors flex items-center gap-1"
          aria-label={`${title} on GitHub`}
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="13"
            height="13"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
          </svg>
          {t.projects.github}
        </a>
      )
    }
    {
      demo && (
        <a
          href={demo}
          target="_blank"
          rel="noopener noreferrer"
          class="text-xs text-text-muted hover:text-text-secondary transition-colors"
          aria-label={`Live demo for ${title}`}
        >
          {t.projects.demo}
        </a>
      )
    }
  </div>
</article>
