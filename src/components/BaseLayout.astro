---
import '@/styles/global.css';
import Navbar from '@/components/Navbar.astro';
import Footer from '@/components/Footer.astro';
import type { Locale } from '@/i18n/types';
import { useTranslations, getAlternateURL } from '@/i18n/index';

interface Props {
  title: string;
  description: string;
  locale?: Locale;
  canonicalURL?: string;
  ogImage?: string;
}

const {
  title,
  description,
  locale = 'en',
  canonicalURL = Astro.url.href,
  ogImage,
} = Astro.props;

const t = useTranslations(locale);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const alternateLocale: Locale = locale === 'en' ? 'es' : 'en';
const alternateURL = getAlternateURL(Astro.url, alternateLocale, base);
const alternateLang = alternateLocale === 'en' ? 'en' : 'es';
---

<!doctype html>
<html lang={locale} class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Lucas Burdman" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Alternate language -->
    <link rel="alternate" hreflang={alternateLang} href={alternateURL} />
    <link rel="alternate" hreflang={locale} href={canonicalURL} />
    <link rel="alternate" hreflang="x-default" href={`${base}/`} />

    <!-- OpenGraph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="Lucas Burdman" />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    <!-- Preload Inter font -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <meta name="generator" content={Astro.generator} />
  </head>
  <body>
    <Navbar locale={locale} t={t} base={base} />
    <main id="main-content" tabindex="-1">
      <slot />
    </main>
    <Footer locale={locale} t={t} base={base} />
  </body>
</html>
