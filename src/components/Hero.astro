---
import type { UIStrings } from '@/i18n/types';

interface Props {
  t: UIStrings;
  base: string;
}

const { t, base } = Astro.props;
---

<section class="relative overflow-hidden py-24 md:py-32" aria-label="Hero">
  <div class="section-container relative">
    <div class="grid gap-10 lg:grid-cols-[1.15fr_0.85fr] lg:items-start">
      <div class="max-w-3xl">
        <div class="animate-in mb-6 inline-flex items-center gap-2">
          <span class="h-px w-8 bg-accent opacity-60"></span>
          <span class="eyebrow">
            Electronic Engineer · ML · Applied AI
          </span>
        </div>

        <h1
          class="animate-in animate-in-delay-1 text-5xl md:text-6xl lg:text-7xl font-semibold tracking-tight text-text-primary leading-none mb-6"
        >
          {t.hero.name}
        </h1>

        <p class="animate-in animate-in-delay-2 text-2xl md:text-3xl font-light text-accent-hover tracking-tight mb-6 max-w-2xl">
          {t.hero.tagline}
        </p>

        <p class="animate-in animate-in-delay-3 text-base md:text-lg text-text-secondary leading-relaxed max-w-2xl mb-10">
          {t.hero.intro}
        </p>

        <div class="animate-in animate-in-delay-4 flex flex-wrap gap-3">
          <a href={`${base}/projects`} class="btn-primary" id="hero-cta-projects">
            {t.hero.ctaProjects}
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path>
            </svg>
          </a>
          <a href={`${base}/notes`} class="btn-ghost" id="hero-cta-notes">
            {t.hero.ctaNotes}
          </a>
          <a href="#contact" class="btn-ghost" id="hero-cta-contact">
            {t.hero.ctaContact}
          </a>
          <a
            href={`${base}/assets/resume.pdf`}
            class="btn-ghost"
            id="hero-cta-resume"
            target="_blank"
            rel="noopener noreferrer"
            download
          >
            {t.hero.ctaResume}
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line>
            </svg>
          </a>
        </div>

        <div class="mt-8 flex flex-wrap gap-2">
          <span class="metric-chip">{t.areas.items.ml}</span>
          <span class="metric-chip">{t.areas.items.appliedAI}</span>
          <span class="metric-chip">{t.areas.items.backend}</span>
          <span class="metric-chip">{t.areas.items.privacyLLM}</span>
        </div>
      </div>

      <aside class="hero-panel animate-in animate-in-delay-2 p-6 md:p-8 lg:sticky lg:top-24">
        <div class="flex items-start justify-between gap-4 mb-6">
          <div>
            <p class="eyebrow mb-2">{t.about.currently}</p>
            <h2 class="text-xl font-semibold text-text-primary tracking-tight">{t.areas.heading}</h2>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-3 mb-6">
          <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-4">
            <p class="text-[0.65rem] uppercase tracking-[0.2em] text-text-muted mb-2">{t.areas.items.ml}</p>
            <p class="text-sm font-medium text-text-primary">{t.areas.items.appliedAI}</p>
          </div>
          <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-4">
            <p class="text-[0.65rem] uppercase tracking-[0.2em] text-text-muted mb-2">{t.areas.items.backend}</p>
            <p class="text-sm font-medium text-text-primary">{t.areas.items.privacyLLM}</p>
          </div>
        </div>

        <div class="space-y-3">
          {t.about.interests.map((interest, index) => (
            <div class="flex items-start gap-3 rounded-2xl border border-white/5 bg-black/20 px-4 py-3">
              <span class="mt-1 h-2 w-2 rounded-full bg-accent shrink-0" aria-hidden="true"></span>
              <div>
                <p class="text-xs font-semibold uppercase tracking-[0.18em] text-text-muted">0{index + 1}</p>
                <p class="text-sm text-text-secondary leading-relaxed">{interest}</p>
              </div>
            </div>
          ))}
        </div>
      </aside>
    </div>
  </div>
</section>
