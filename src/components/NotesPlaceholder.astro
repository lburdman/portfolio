---
import type { UIStrings } from '@/i18n/types';

interface Props {
  t: UIStrings;
  base: string;
}

const { t, base } = Astro.props;
---

<section class="py-20 border-t border-surface-border" aria-labelledby="notes-heading">
  <div class="section-container">
    <div class="mb-10">
      <h2 id="notes-heading" class="section-heading">{t.notes.heading}</h2>
      <p class="section-subtitle">{t.notes.subtitle}</p>
    </div>

    <div class="relative rounded-card border border-surface-border bg-surface-elevated overflow-hidden">
      <!-- Accent line -->
      <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-accent/50 via-accent-hover/30 to-transparent" aria-hidden="true"></div>

      <div class="px-8 py-12 flex flex-col sm:flex-row items-start sm:items-center gap-8">
        <!-- Icon -->
        <div
          class="shrink-0 flex h-14 w-14 items-center justify-center rounded-xl bg-accent/10 border border-accent/20 text-accent"
          aria-hidden="true"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/>
            <polyline points="14 2 14 8 20 8"/>
            <line x1="16" y1="13" x2="8" y2="13"/>
            <line x1="16" y1="17" x2="8" y2="17"/>
            <line x1="10" y1="9" x2="8" y2="9"/>
          </svg>
        </div>

        <!-- Content -->
        <div class="flex-1">
          <div class="flex items-center gap-3 mb-3">
            <h3 class="text-base font-semibold text-text-primary">{t.notes.comingSoon}</h3>
            <span class="tag">{t.notes.comingSoon}</span>
          </div>
          <p class="text-sm text-text-secondary leading-relaxed max-w-lg">{t.notes.placeholder}</p>
        </div>
      </div>
    </div>
  </div>
</section>
